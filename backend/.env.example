# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development              # development | production
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL (current)
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require
# Local PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/civicalign
# SQLite (zero-config local dev fallback)
# DATABASE_URL=sqlite:///civicalign.db

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI must include: http://localhost:5173 (dev) and your prod domain
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ── AI / Gemini ───────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800        # 50 MB in bytes

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── Email (optional — not required for hackathon mode) ───────────────────────
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=app-password

# ── Seed / Admin credentials ──────────────────────────────────────────────────
# Admin created by seed.py:
#   Email:    admin@civicalign.com
#   Password: Admin@123
# Test citizens: priya/rahul/anjali/suresh/meena@example.com  /  Test@1234
